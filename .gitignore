# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.env
*.egg-info/

# Tidy3D simulation artifacts (regeneratable, often large)
*.hdf5
*.h5
simulations/
sim_data/
tidy3d_cache/
# Local result caches — paid-for sim outputs, but binary and large.
# Journals are the source of truth; do not delete the cache directories
# locally, just keep them out of git.
cache/
cache_step2/

# Run logs (verbose; the journals capture the durable record)
*.log

# Claude Code local agent state
.claude/

# Generated outputs
field_plots/
*.png
*.jpg
*.gif
*.mp4
!docs/**/*.png

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Secrets — never commit these
*.key
credentials.json
.tidy3d_credentials
# Local wheel files (PhotonForge etc.) - re-download from CI artifacts if needed
wheels/*.whl